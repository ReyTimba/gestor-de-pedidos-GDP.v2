{
  "name": "gpd.v2-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "render:build": "prisma generate && tsc --noEmit -p tsconfig.json",
    "start": "tsx src/server.ts",
    "db:migrate": "prisma migrate dev --name init && prisma generate",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "prisma": "^7.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
