{
  "name": "gpd.v2",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "frontend": "npm --workspace frontend run dev",
    "backend": "npm --workspace backend run dev",
    "client": "npm run frontend",
    "server": "npm run backend",
    "db:migrate": "npm --workspace backend run db:migrate",
    "db:generate": "npm --workspace backend run db:generate",
    "db:validate": "npm --workspace backend run db:validate",
    "db:studio": "npm --workspace backend run db:studio",
    "db:up": "npm --workspace backend run db:up",
    "db:down": "npm --workspace backend run db:down",
    "build": "npm --workspace frontend run build && npm --workspace backend run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
